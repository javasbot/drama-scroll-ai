# === 吃瓜日报 Node.js BFF 环境变量 ===

# --- 应用 ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# --- Supabase (https://supabase.com) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Upstash Redis (https://upstash.com) ---
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- Groq LLM (https://groq.com) ---
GROQ_API_KEY=

# --- Pinecone 向量数据库 (https://pinecone.io) ---
PINECONE_API_KEY=
PINECONE_INDEX=drama-stories

# --- Clerk 认证 (https://clerk.com) ---
CLERK_SECRET_KEY=

# --- Stripe 支付 (https://stripe.com) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend 邮件 (https://resend.com) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@dramascroll.app

# --- Sentry 错误追踪 (https://sentry.io) ---
SENTRY_DSN=

# --- PostHog 数据分析 (https://posthog.com) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
